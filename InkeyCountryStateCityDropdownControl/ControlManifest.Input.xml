<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control
    namespace="InkeyCountryStateCityDropdown"
    constructor="InkeyCountryStateCityDropdownControl"
    version="10.0.2"
    display-name-key="InkeyCountryStateCityDropdownControl"
    description-key="InkeyCountryStateCityDropdownControl description"
    control-type="standard">

    <!--
      external-service-usage node declares whether this 3rd party PCF control
      is using external service or not.
    -->
    <external-service-usage enabled="true">
      <domain>countriesnow.space</domain>
    </external-service-usage>

    <!--
      Property node's of-type attribute can be of-type-group attribute.

      Example:

      <type-group name="numbers">
        <type>Whole.None</type>
        <type>Currency</type>
        <type>FP</type>
        <type>Decimal</type>
      </type-group>

      <property
        name="sampleProperty"
        display-name-key="Property_Display_Key"
        description-key="Property_Desc_Key"
        of-type-group="numbers"
        usage="bound"
        required="true" />
    -->

    <!-- Main bound field where the selected Country, State, and City value will be stored -->
    <property
      name="value"
      display-name-key="Value"
      of-type="SingleLine.Text"
      usage="bound"
      required="false" />

    <!-- Defines the control mode: Country, State, or City -->
    <property
      name="mode"
      display-name-key="Mode"
      of-type="SingleLine.Text"
      usage="input"
      required="true" />

    <!-- Optional default or preselected country value -->
    <property
      name="country"
      display-name-key="Country"
      of-type="SingleLine.Text"
      usage="input" />

    <!-- Optional default or preselected state value -->
    <property
      name="state"
      display-name-key="State"
      of-type="SingleLine.Text"
      usage="input" />

    <resources>
      <code path="index.ts" order="1" />

      <!--
      <css
        path="css/InkeyCountryStateCityDropdownControl.css"
        order="1" />

      <resx
        path="strings/InkeyCountryStateCityDropdownControl.1033.resx"
        version="1.0.0" />
      -->
    </resources>

